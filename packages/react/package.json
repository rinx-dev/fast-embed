{
  "name": "@fast-embed/react",
  "version": "0.0.0",
  "description": "SSR-safe React wrappers for fast video embeds.",
  "type": "module",
  "sideEffects": ["./src/styles.css"],
  "files": ["dist", "src/styles.css"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./src/styles.css"
  },
  "peerDependencies": {
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "dependencies": {
    "@fast-embed/core": "workspace:*"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "test": "vitest run --project react",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
