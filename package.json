{
  "name": "fast-embed-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "build": "corepack pnpm -r --filter ./packages/* build && corepack pnpm --filter react-vite-example build",
    "dev": "corepack pnpm --filter react-vite-example dev",
    "lint": "eslint .",
    "test": "corepack pnpm test:unit && corepack pnpm test:e2e",
    "test:e2e": "playwright test",
    "test:unit": "vitest run",
    "typecheck": "corepack pnpm -r --filter ./packages/* typecheck && corepack pnpm --filter react-vite-example typecheck"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@eslint/js": "^9.25.1",
    "@playwright/test": "^1.55.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^7.1.7",
    "vitest": "^4.0.4"
  }
}
